<!-- Cron表达式编辑器组件 -->
<view class="cron-editor">
  <view class="editor-header">
    <text class="header-title">{{title}}</text>
    <text class="header-field">{{fieldName}}</text>
  </view>
  
  <!-- 可滚动内容区域 -->
  <scroll-view class="editor-scroll-content" scroll-y enable-flex>
  <!-- 快捷选项 -->
  <view class="quick-options">
    <view 
      class="option-item {{selectedType === 'any' ? 'active' : ''}}"
      bindtap="selectType"
      data-type="any"
    >
      <text class="option-label">任意值</text>
      <text class="option-value">*</text>
    </view>
    
    <view 
      class="option-item {{selectedType === 'specific' ? 'active' : ''}}"
      bindtap="selectType"
      data-type="specific"
    >
      <text class="option-label">指定值</text>
      <text class="option-value">5</text>
    </view>
    
    <view 
      class="option-item {{selectedType === 'interval' ? 'active' : ''}}"
      bindtap="selectType"
      data-type="interval"
    >
      <text class="option-label">间隔</text>
      <text class="option-value">*/5</text>
    </view>
    
    <view 
      class="option-item {{selectedType === 'range' ? 'active' : ''}}"
      bindtap="selectType"
      data-type="range"
    >
      <text class="option-label">范围</text>
      <text class="option-value">1-10</text>
    </view>
    
    <view 
      class="option-item {{selectedType === 'multiple' ? 'active' : ''}}"
      bindtap="selectType"
      data-type="multiple"
    >
      <text class="option-label">多个值</text>
      <text class="option-value">1,3,5</text>
    </view>
  </view>
  
  <!-- 配置区域 -->
  <view class="config-area">
    <!-- 任意值 -->
    <view class="config-panel" wx:if="{{selectedType === 'any'}}">
      <text class="panel-hint">将在每个{{fieldName}}触发</text>
    </view>
    
    <!-- 指定值 -->
    <view class="config-panel" wx:if="{{selectedType === 'specific'}}">
      <view class="input-row">
        <text class="input-label">值:</text>
        <input 
          class="config-input" 
          type="number" 
          value="{{specificValue}}"
          bindinput="onSpecificChange"
          placeholder="输入具体值"
        />
        <text class="input-unit">{{unit}}</text>
      </view>
      <text class="panel-hint">在{{specificValue || '?'}}{{unit}}时触发</text>
    </view>
    
    <!-- 间隔 -->
    <view class="config-panel" wx:if="{{selectedType === 'interval'}}">
      <view class="input-row">
        <text class="input-label">每隔:</text>
        <input 
          class="config-input" 
          type="number" 
          value="{{intervalValue}}"
          bindinput="onIntervalChange"
          placeholder="间隔值"
        />
        <text class="input-unit">{{unit}}</text>
      </view>
      <text class="panel-hint">每隔{{intervalValue || '?'}}{{unit}}触发一次</text>
    </view>
    
    <!-- 范围 -->
    <view class="config-panel" wx:if="{{selectedType === 'range'}}">
      <view class="input-row">
        <text class="input-label">从:</text>
        <input 
          class="config-input" 
          type="number" 
          value="{{rangeStart}}"
          bindinput="onRangeStartChange"
          placeholder="起始值"
        />
        <text class="input-separator">到</text>
        <input 
          class="config-input" 
          type="number" 
          value="{{rangeEnd}}"
          bindinput="onRangeEndChange"
          placeholder="结束值"
        />
        <text class="input-unit">{{unit}}</text>
      </view>
      <view class="input-row" wx:if="{{showRangeStep}}">
        <text class="input-label">间隔:</text>
        <input 
          class="config-input" 
          type="number" 
          value="{{rangeStep}}"
          bindinput="onRangeStepChange"
          placeholder="可选"
        />
        <text class="input-unit">{{unit}}</text>
      </view>
      <text class="panel-hint">在{{rangeStart || '?'}}-{{rangeEnd || '?'}}{{rangeStep ? '/' + rangeStep : ''}}范围内触发</text>
    </view>
    
    <!-- 多个值 -->
    <view class="config-panel" wx:if="{{selectedType === 'multiple'}}">
      <view class="input-row">
        <text class="input-label">值列表:</text>
        <input 
          class="config-input full" 
          value="{{multipleValues}}"
          bindinput="onMultipleChange"
          placeholder="用逗号分隔，如: 1,3,5,7"
        />
      </view>
      <text class="panel-hint">在{{multipleValues || '?'}}时触发</text>
      
      <!-- 星期快捷选项 -->
      <view class="quick-select" wx:if="{{unit === ''}}">
        <text class="quick-label">快捷选择:</text>
        <view class="quick-buttons">
          <button class="quick-btn" bindtap="onQuickSelect" data-value="1,2,3,4,5">工作日</button>
          <button class="quick-btn" bindtap="onQuickSelect" data-value="0,6">周末</button>
          <button class="quick-btn" bindtap="onQuickSelect" data-value="1,3,5">单周</button>
        </view>
      </view>
      
      <!-- 月份快捷选项 -->
      <view class="quick-select" wx:if="{{unit === '月'}}">
        <text class="quick-label">快捷选择:</text>
        <view class="quick-buttons">
          <button class="quick-btn" bindtap="onQuickSelect" data-value="1,4,7,10">季度首月</button>
          <button class="quick-btn" bindtap="onQuickSelect" data-value="3,6,9,12">季度末月</button>
          <button class="quick-btn" bindtap="onQuickSelect" data-value="1,2,3">第一季度</button>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 生成的表达式 -->
  <view class="expression-result {{expressionValid ? 'valid' : 'invalid'}}">
    <view class="result-label">生成的表达式:</view>
    <view class="result-value">{{expression}}</view>
    <view class="result-message">{{expressionMessage}}</view>
  </view>
  </scroll-view>
  
  <!-- 操作按钮（固定在底部） -->
  <view class="action-buttons">
    <button class="btn-cancel" bindtap="onCancel">取消</button>
    <button class="btn-confirm" bindtap="onConfirm">保存并生效</button>
  </view>
</view>

