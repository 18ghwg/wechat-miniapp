  "lint-staged": {
    "*.{js, ts}": "eslint --cache --fix",
    "*.{js,ts,wxml,html,json,css,less}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "dayjs": "^1.9.3",
    "tdesign-miniprogram": "1.9.5",
    "tslib": "^1.11.1"
