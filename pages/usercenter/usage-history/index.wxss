/* 功能使用记录页面样式 */
.usage-history-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 统计概览 */
.stats-overview {
  margin-bottom: 24rpx;
}

.overview-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.header-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-grid {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
  backdrop-filter: blur(10rpx);
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
  line-height: 1;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.most-used {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx;
  backdrop-filter: blur(10rpx);
}

.most-used-label-wrapper {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.most-used-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

.most-used-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.most-used-feature {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.most-used-feature .feature-icon {
  font-size: 40rpx;
}

.most-used-feature .feature-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.most-used-feature .feature-count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 功能列表区域 */
.feature-list-section {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  padding: 24rpx 24rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.filter-tabs {
  display: flex;
  gap: 12rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-weight: 600;
}

/* 功能列表 */
.feature-list {
  padding: 8rpx 0;
}

.feature-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.2s ease;
}

.feature-card:active {
  background: #f8f9fa;
}

.feature-card:last-child {
  border-bottom: none;
}

.feature-card.not-used {
  opacity: 0.6;
}

.feature-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.feature-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
}

.feature-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.feature-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.feature-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feature-desc {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feature-desc.not-used-text {
  color: #ccc;
  font-style: italic;
}

.feature-arrow {
  width: 36rpx;
  height: 36rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
  transform: rotate(180deg);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-icon-img {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
  max-width: 500rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

