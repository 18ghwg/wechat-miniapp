/* 意见反馈页面 - Macaron 马卡龙风格 */
@import '/style/macaron-theme.wxss';

/* 页面容器 */
.container {
  min-height: 100vh;
  background: var(--background);
  padding: 30rpx;
}

/* 欢迎区域 - cartoon-card 样式 */
.welcome-section {
  background: linear-gradient(135deg, var(--color-peach-macaron) 0%, var(--color-yellow-macaron) 100%);
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 32rpx;
}

.welcome-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.welcome-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.welcome-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--foreground);
  font-weight: var(--font-weight-medium);
}

/* 表单区域 - cartoon-card 样式 */
.form-section {
  margin-bottom: 30rpx;
  padding: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.section-icon-img {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--foreground);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-icon-img {
  width: 24rpx;
  height: 24rpx;
  margin-right: 10rpx;
  opacity: 0.7;
}

.label-text {
  font-size: 26rpx;
  font-weight: var(--font-weight-bold);
  color: var(--foreground);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  opacity: 0.8;
}


/* 反馈类型单选组 - 马卡龙风格 */
.type-radio-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.type-radio-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-radius: var(--radius-lg);
  border: 4rpx solid var(--border);
  background: var(--muted);
  transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  min-height: 88rpx;
  position: relative;
}

.type-radio-item.selected {
  border-color: var(--foreground);
  background: var(--color-orange-light);
  box-shadow: 6rpx 6rpx 0rpx var(--foreground);
  transform: translateY(-4rpx);
}

.type-radio-item:active {
  transform: translateY(0);
  box-shadow: 2rpx 2rpx 0rpx var(--foreground);
}

.type-radio-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.type-icon-img {
  width: 28rpx;
  height: 28rpx;
}

.type-radio-label {
  flex: 1;
  font-size: 28rpx;
  font-weight: var(--font-weight-bold);
  color: var(--foreground);
}

.type-check-mark {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--foreground);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.check-icon-img {
  width: 24rpx;
  height: 24rpx;
}

/* 多行文本区域 - form-textarea-macaron 样式 */
.textarea-wrapper {
  position: relative;
}

.form-textarea-macaron {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx 28rpx;
  padding-bottom: 60rpx;
  background: var(--muted);
  border: 4rpx solid var(--border);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  font-weight: var(--font-weight-medium);
  color: var(--foreground);
  box-sizing: border-box;
  line-height: 1.6;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.form-textarea-macaron:focus {
  border-color: var(--primary);
  background: var(--card);
  box-shadow: 0 0 0 6rpx rgba(255, 159, 67, 0.15);
  transform: translateY(-4rpx);
}

.char-count {
  position: absolute;
  right: 20rpx;
  bottom: 16rpx;
  font-size: 22rpx;
  color: var(--muted-foreground);
}

.char-current {
  color: var(--primary);
  font-weight: var(--font-weight-bold);
}

.char-separator {
  margin: 0 4rpx;
}

.char-max {
  opacity: 0.6;
}

/* 提交按钮 - macaron-btn-peach 样式 */
.submit-btn {
  width: 100%;
  margin-top: 16rpx;
  padding: 32rpx;
  font-size: 32rpx;
  min-height: 88rpx;
}

.submit-btn.loading {
  opacity: 0.8;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

.submitting-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.loading-spinner-small {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(94, 78, 62, 0.3);
  border-left-color: var(--foreground);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}


/* 功能关闭提示 - cartoon-card 样式 */
.disabled-notice {
  text-align: center;
  padding: 60rpx 40rpx;
  background: var(--color-yellow-macaron);
  margin-bottom: 30rpx;
}

.notice-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto 24rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.notice-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.notice-title {
  display: block;
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  color: var(--foreground);
  margin-bottom: 16rpx;
}

.notice-content {
  font-size: 26rpx;
  color: var(--foreground);
  line-height: 1.6;
  opacity: 0.8;
}

/* 历史反馈区域 */
.history-section {
  margin-bottom: 30rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  background: var(--card);
  border: 6rpx solid var(--foreground);
  border-radius: var(--radius-cartoon);
  box-shadow: var(--shadow-btn);
  margin-bottom: 20rpx;
  min-height: 88rpx;
  transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.history-header:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 0rpx 0rpx 0rpx var(--foreground);
}

.history-header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.history-icon-img {
  width: 28rpx;
  height: 28rpx;
}

.history-title {
  font-size: 30rpx;
  font-weight: var(--font-weight-bold);
  color: var(--foreground);
}

.history-count {
  margin-left: 8rpx;
}

.toggle-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: var(--color-orange-light);
  border-radius: 999rpx;
  border: 3rpx solid var(--foreground);
}

.toggle-text {
  font-size: 24rpx;
  font-weight: var(--font-weight-bold);
  color: var(--foreground);
}

.toggle-icon {
  font-size: 20rpx;
  transition: transform 0.3s ease;
}

.toggle-icon.expanded {
  transform: rotate(180deg);
}

/* 反馈列表 - cartoon-card 列表样式 */
.feedback-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feedback-item {
  padding: 24rpx;
  background: var(--card);
}

.feedback-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.feedback-title {
  font-size: 28rpx;
  font-weight: var(--font-weight-bold);
  color: var(--foreground);
  flex: 1;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feedback-status {
  flex-shrink: 0;
}

/* 状态徽章颜色变体 */
.status-pending {
  background: var(--color-yellow-macaron);
  color: var(--foreground);
}

.status-processing {
  background: var(--color-blue-macaron);
  color: var(--foreground);
}

.status-closed {
  background: var(--muted);
  color: var(--foreground);
}

.feedback-content {
  display: block;
  font-size: 26rpx;
  color: var(--foreground);
  line-height: 1.5;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  opacity: 0.8;
}

.feedback-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.feedback-time-wrapper {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.time-icon-img {
  width: 18rpx;
  height: 18rpx;
  opacity: 0.6;
}

.feedback-time {
  font-size: 22rpx;
  color: var(--muted-foreground);
}

.feedback-type-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 14rpx;
  background: var(--color-orange-light);
  border-radius: 999rpx;
  border: 2rpx solid var(--foreground);
}

.type-badge-icon-img {
  width: 16rpx;
  height: 16rpx;
}

.feedback-type-text {
  font-size: 20rpx;
  font-weight: var(--font-weight-bold);
  color: var(--foreground);
}

/* 管理员回复区域 */
.feedback-reply {
  background: var(--color-mint-macaron);
  border-radius: var(--radius-lg);
  padding: 20rpx;
  border-left: 8rpx solid var(--foreground);
  margin-top: 8rpx;
}

.reply-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.reply-icon-img {
  width: 18rpx;
  height: 18rpx;
}

.reply-label {
  font-size: 22rpx;
  font-weight: var(--font-weight-bold);
  color: var(--foreground);
}

.reply-content {
  font-size: 24rpx;
  color: var(--foreground);
  line-height: 1.5;
}

/* 管理员功能区域 */
.admin-section {
  text-align: center;
  padding: 20rpx 0;
}

.admin-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 48rpx;
  min-height: 88rpx;
}

.admin-btn-icon-img {
  width: 24rpx;
  height: 24rpx;
}

/* 减少动画（可访问性） */
@media (prefers-reduced-motion: reduce) {
  .type-radio-item,
  .form-textarea-macaron,
  .cartoon-card,
  .macaron-btn,
  .history-header,
  .toggle-icon {
    animation: none;
    transition: none;
  }
  
  .loading-spinner-small {
    animation: none;
  }
}
