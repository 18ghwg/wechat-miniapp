.privacy-container {
  min-height: 100vh;
  background: var(--color-orange-light);
  padding: 48rpx;
  box-sizing: border-box;
}

.privacy-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.privacy-title {
  font-size: 48rpx;
  font-weight: var(--font-weight-bold);
  color: var(--foreground);
  display: block;
}

.privacy-content {
  height: calc(100vh - 300rpx);
  background: var(--card);
  border: 6rpx solid var(--foreground);
  border-radius: 48rpx;
  box-shadow: 12rpx 12rpx 0rpx var(--foreground);
  padding: 48rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 48rpx;
}

.section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  color: var(--foreground);
  display: block;
  margin-bottom: 24rpx;
}

.section-content {
  font-size: 28rpx;
  color: var(--foreground);
  line-height: 1.8;
  opacity: 0.8;
}

.back-button {
  margin-top: 48rpx;
  text-align: center;
}

.back-btn {
  width: 200rpx;
  height: 80rpx;
  background: var(--primary);
  color: var(--foreground);
  border: 6rpx solid var(--foreground);
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: var(--font-weight-bold);
  box-shadow: var(--shadow-btn);
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn::after {
  border: none;
}
