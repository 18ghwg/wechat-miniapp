<!--用户设置页面 - 马卡龙风格-->
<!--需求 7.1, 7.2, 7.3: 设置页面转换为分组的 cartoon-card 列表样式-->
<view class="settings-container">
  <!-- 通知设置 - cartoon-card 列表样式 -->
  <view class="settings-group">
    <view class="group-header">
      <image class="group-icon" src="/assets/icons/bell.png" mode="aspectFit"/>
      <text class="group-title">通知设置</text>
    </view>
    <view class="settings-card">
      <!-- 推送通知开关 -->
      <view class="settings-item has-border">
        <view class="item-left">
          <view class="item-icon-box" style="background: var(--color-peach-macaron);">
            <image class="item-icon-img" src="/assets/icons/bell.png" mode="aspectFit"/>
          </view>
          <view class="item-content">
            <text class="item-label">推送通知</text>
            <text class="item-desc">接收系统推送消息</text>
          </view>
        </view>
        <switch 
          class="macaron-switch"
          checked="{{settings.pushNotification}}"
          bindchange="onPushNotificationChange"
          color="#FF9F43"
        />
      </view>
      
      <!-- 声音开关 -->
      <view class="settings-item">
        <view class="item-left">
          <view class="item-icon-box" style="background: var(--color-mint-macaron);">
            <image class="item-icon-img" src="/assets/icons/megaphone.png" mode="aspectFit"/>
          </view>
          <view class="item-content">
            <text class="item-label">通知声音</text>
            <text class="item-desc">收到通知时播放声音</text>
          </view>
        </view>
        <switch 
          class="macaron-switch"
          checked="{{settings.notificationSound}}"
          bindchange="onNotificationSoundChange"
          color="#FF9F43"
          disabled="{{!settings.pushNotification}}"
        />
      </view>
    </view>
  </view>

  <!-- 显示设置 - cartoon-card 列表样式 -->
  <view class="settings-group">
    <view class="group-header">
      <image class="group-icon" src="/assets/icons/sun.png" mode="aspectFit"/>
      <text class="group-title">显示设置</text>
    </view>
    <view class="settings-card">
      <!-- 主题选择 -->
      <view class="settings-item has-border" bindtap="onThemePickerTap">
        <view class="item-left">
          <view class="item-icon-box" style="background: var(--color-lavender-macaron);">
            <image class="item-icon-img" src="/assets/icons/sun.png" mode="aspectFit"/>
          </view>
          <view class="item-content">
            <text class="item-label">主题模式</text>
            <text class="item-desc">选择应用显示主题</text>
          </view>
        </view>
        <view class="item-right">
          <text class="item-value">{{themeOptions[settings.themeIndex]}}</text>
          <text class="item-arrow">›</text>
        </view>
      </view>
      
      <!-- 字体大小选择 -->
      <view class="settings-item" bindtap="onFontSizePickerTap">
        <view class="item-left">
          <view class="item-icon-box" style="background: var(--color-blue-macaron);">
            <image class="item-icon-img" src="/assets/icons/edit.png" mode="aspectFit"/>
          </view>
          <view class="item-content">
            <text class="item-label">字体大小</text>
            <text class="item-desc">调整文字显示大小</text>
          </view>
        </view>
        <view class="item-right">
          <text class="item-value">{{fontSizeOptions[settings.fontSizeIndex]}}</text>
          <text class="item-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 隐私设置 - cartoon-card 列表样式 -->
  <view class="settings-group">
    <view class="group-header">
      <image class="group-icon" src="/assets/icons/shield.png" mode="aspectFit"/>
      <text class="group-title">隐私设置</text>
    </view>
    <view class="settings-card">
      <!-- 数据共享开关 -->
      <view class="settings-item">
        <view class="item-left">
          <view class="item-icon-box" style="background: var(--color-pink-macaron);">
            <image class="item-icon-img" src="/assets/icons/shield.png" mode="aspectFit"/>
          </view>
          <view class="item-content">
            <text class="item-label">数据共享</text>
            <text class="item-desc">允许匿名使用数据用于改进服务</text>
          </view>
        </view>
        <switch 
          class="macaron-switch"
          checked="{{settings.dataSharing}}"
          bindchange="onDataSharingChange"
          color="#FF9F43"
        />
      </view>
    </view>
  </view>

  <!-- 关于 - cartoon-card 列表样式 -->
  <view class="settings-group">
    <view class="group-header">
      <image class="group-icon" src="/assets/icons/alert-circle.png" mode="aspectFit"/>
      <text class="group-title">关于</text>
    </view>
    <view class="settings-card">
      <!-- 版本信息 -->
      <view class="settings-item has-border">
        <view class="item-left">
          <view class="item-icon-box" style="background: var(--color-yellow-macaron);">
            <image class="item-icon-img" src="/assets/icons/alert-circle.png" mode="aspectFit"/>
          </view>
          <view class="item-content">
            <text class="item-label">版本信息</text>
            <text class="item-desc">当前版本</text>
          </view>
        </view>
        <view class="item-right">
          <text class="item-value">{{appVersion}}</text>
        </view>
      </view>
      
      <!-- 意见反馈 -->
      <view class="settings-item has-border" bindtap="onFeedbackTap">
        <view class="item-left">
          <view class="item-icon-box" style="background: var(--color-peach-macaron);">
            <image class="item-icon-img" src="/assets/icons/edit.png" mode="aspectFit"/>
          </view>
          <view class="item-content">
            <text class="item-label">意见反馈</text>
            <text class="item-desc">帮助我们改进产品</text>
          </view>
        </view>
        <view class="item-right">
          <text class="item-arrow">›</text>
        </view>
      </view>
      
      <!-- 隐私政策 -->
      <view class="settings-item has-border" bindtap="onPrivacyTap">
        <view class="item-left">
          <view class="item-icon-box" style="background: var(--color-mint-macaron);">
            <image class="item-icon-img" src="/assets/icons/lock.png" mode="aspectFit"/>
          </view>
          <view class="item-content">
            <text class="item-label">隐私政策</text>
            <text class="item-desc">了解我们如何保护您的隐私</text>
          </view>
        </view>
        <view class="item-right">
          <text class="item-arrow">›</text>
        </view>
      </view>
      
      <!-- 服务条款 -->
      <view class="settings-item" bindtap="onTermsTap">
        <view class="item-left">
          <view class="item-icon-box" style="background: var(--color-blue-macaron);">
            <image class="item-icon-img" src="/assets/icons/clipboard.png" mode="aspectFit"/>
          </view>
          <view class="item-content">
            <text class="item-label">服务条款</text>
            <text class="item-desc">查看服务使用条款</text>
          </view>
        </view>
        <view class="item-right">
          <text class="item-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部间距 -->
  <view class="bottom-spacer"></view>
</view>

<!-- 主题选择器弹窗 - macaron 风格 picker -->
<view class="picker-popup" wx:if="{{showThemePicker}}">
  <view class="picker-mask" bindtap="closeThemePicker"></view>
  <view class="picker-content">
    <view class="picker-header">
      <text class="picker-cancel" bindtap="closeThemePicker">取消</text>
      <text class="picker-title">选择主题</text>
      <text class="picker-confirm" bindtap="confirmTheme">确定</text>
    </view>
    <view class="picker-body">
      <view 
        wx:for="{{themeOptions}}" 
        wx:key="index"
        class="picker-option {{tempThemeIndex === index ? 'active' : ''}}"
        data-index="{{index}}"
        bindtap="onThemeSelect"
      >
        <text class="option-text">{{item}}</text>
        <image class="option-check-icon" wx:if="{{tempThemeIndex === index}}" src="/assets/icons/check-circle.png" mode="aspectFit"/>
      </view>
    </view>
  </view>
</view>

<!-- 字体大小选择器弹窗 - macaron 风格 picker -->
<view class="picker-popup" wx:if="{{showFontSizePicker}}">
  <view class="picker-mask" bindtap="closeFontSizePicker"></view>
  <view class="picker-content">
    <view class="picker-header">
      <text class="picker-cancel" bindtap="closeFontSizePicker">取消</text>
      <text class="picker-title">选择字体大小</text>
      <text class="picker-confirm" bindtap="confirmFontSize">确定</text>
    </view>
    <view class="picker-body">
      <view 
        wx:for="{{fontSizeOptions}}" 
        wx:key="index"
        class="picker-option {{tempFontSizeIndex === index ? 'active' : ''}}"
        data-index="{{index}}"
        bindtap="onFontSizeSelect"
      >
        <text class="option-text" style="font-size: {{fontSizePreview[index]}}rpx;">{{item}}</text>
        <image class="option-check-icon" wx:if="{{tempFontSizeIndex === index}}" src="/assets/icons/check-circle.png" mode="aspectFit"/>
      </view>
    </view>
  </view>
</view>

<t-toast id="t-toast" />
