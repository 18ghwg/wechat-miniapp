/* 国网账号管理页面样式 - Macaron Theme */
@import '/style/macaron-theme.wxss';

.account-manage-container {
  padding: 0 30rpx 30rpx;
  background-color: var(--background);
  min-height: 100vh;
}

/* 页面标题 */
.page-header {
  padding: 40rpx 0 30rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  background: var(--color-yellow-macaron);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  border: 4rpx solid var(--foreground);
  box-shadow: 6rpx 6rpx 0rpx var(--foreground);
}

.header-icon {
  width: 56rpx;
  height: 56rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: var(--font-weight-bold);
  color: var(--foreground);
  margin-bottom: 12rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--muted-foreground);
}

/* 统计卡片区域 */
.stats-cards {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 16rpx;
}

.stat-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.stat-content {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--primary);
  line-height: 1;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--muted-foreground);
  font-weight: var(--font-weight-medium);
}


/* 操作按钮区域 */
.action-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.action-top-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 32rpx;
  background: white;
  border: 6rpx solid #5E4E3E;
  border-radius: 60rpx;
  box-shadow: 0rpx 8rpx 0rpx #5E4E3E;
  transition: all 0.2s;
}

.action-top-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0rpx 6rpx 0rpx #5E4E3E;
}

.action-top-btn .btn-icon-text {
  font-size: 40rpx;
  font-weight: 900;
  color: #5E4E3E;
  line-height: 1;
}

.action-top-btn .btn-icon-img {
  width: 32rpx;
  height: 32rpx;
}

.action-top-btn .btn-text {
  font-size: 28rpx;
  font-weight: 900;
  color: #5E4E3E;
}

.add-button,
.refresh-button {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-height: 88rpx;
  font-size: 28rpx;
}

.btn-icon-img {
  width: 32rpx;
  height: 32rpx;
}

.btn-icon-text {
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
}

.btn-text {
  font-weight: var(--font-weight-bold);
}

/* 账号列表 */
.account-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.account-card {
  padding: 24rpx;
  position: relative;
  overflow: visible;
}

.account-card.active-account {
  background: linear-gradient(135deg, #F5E6D3 0%, #E8D4B8 100%);
  border-color: var(--foreground);
  box-shadow: 0rpx 0rpx 0rpx 4rpx rgba(255, 200, 100, 0.3);
}

/* 卡片头部 */
.card-header {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.avatar-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, var(--color-yellow-macaron) 0%, var(--color-peach-macaron) 100%);
  flex-shrink: 0;
  border: 4rpx solid var(--foreground);
  box-shadow: 6rpx 6rpx 0rpx var(--foreground);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--foreground);
  letter-spacing: 2rpx;
  line-height: 1;
  text-align: center;
}

.account-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
}

.account-main-info {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12rpx;
}

.phone-number {
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  color: var(--foreground);
  letter-spacing: 1rpx;
}

.status-badges {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

/* Status Badge 样式 - 扩展 macaron-theme.wxss */
.status-warning {
  background: var(--color-yellow-macaron);
  color: var(--foreground);
}

.status-error {
  background: var(--color-pink-macaron);
  color: var(--foreground);
}

.account-details {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--muted-foreground);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-icon {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

.badge-with-icon {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.badge-icon {
  width: 20rpx;
  height: 20rpx;
}

/* 卡片操作区 */
.card-actions {
  display: flex;
  gap: 32rpx;
  justify-content: center;
  padding-top: 48rpx;
}

.action-btn-circle {
  width: 160rpx;
  height: 160rpx;
  background: white;
  border: 6rpx solid #5E4E3E;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 8rpx 8rpx 0rpx #5E4E3E;
  transition: all 0.2s;
}

.action-btn-circle:active {
  transform: translateY(2rpx);
  box-shadow: none;
}

.action-icon-img {
  width: 32rpx;
  height: 32rpx;
}

.action-btn-text {
  font-size: 22rpx;
  font-weight: 900;
  color: #5E4E3E;
}

.btn-disabled {
  opacity: 0.5;
  cursor: default;
}

.btn-disabled:active {
  transform: none;
  box-shadow: 8rpx 8rpx 0rpx #5E4E3E;
}


/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon-img {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  color: var(--foreground);
  margin-bottom: 12rpx;
}

.empty-subtitle {
  font-size: 26rpx;
  color: var(--muted-foreground);
  line-height: 1.5;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 80rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--muted-foreground);
}

/* 弹窗样式 */
.popup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(94, 78, 62, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.popup-container {
  width: 100%;
  max-width: 600rpx;
  max-height: 85vh;
  background: var(--card);
  overflow: hidden;
  padding: 0;
  display: flex;
  flex-direction: column;
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background-color: var(--color-orange-light);
  border-bottom: 4rpx solid var(--foreground);
  border-radius: var(--radius-cartoon) var(--radius-cartoon) 0 0;
  flex-shrink: 0;
}

.popup-title {
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  color: var(--foreground);
}

.popup-close {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  border: 3rpx solid var(--foreground);
}

.popup-close:active {
  background: rgba(255, 255, 255, 0.5);
  transform: scale(0.95);
}

.close-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.popup-content {
  padding: 30rpx;
  overflow-y: auto;
  flex: 1;
}

/* 表单样式 */
.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: var(--font-weight-medium);
  color: var(--foreground);
  margin-bottom: 12rpx;
}

.input-error {
  border-color: var(--destructive) !important;
  background: #fff5f5 !important;
}

.input-disabled {
  background: var(--muted) !important;
  color: var(--muted-foreground) !important;
}

.form-error {
  display: block;
  color: var(--destructive);
  font-size: 24rpx;
  margin-top: 10rpx;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: var(--muted-foreground);
  margin-top: 10rpx;
}

.form-tips {
  background: var(--color-orange-light);
  padding: 20rpx;
  border-radius: var(--radius-lg);
  margin-top: 20rpx;
  border: 2rpx solid var(--border);
}

.tips-content {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.tips-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.tips-text {
  color: var(--foreground);
  font-size: 26rpx;
  line-height: 1.5;
  flex: 1;
}

/* 自定义下拉选择器样式 */
.status-group {
  position: relative;
}

.custom-select {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border: 4rpx solid var(--border);
  border-radius: var(--radius-lg);
  background-color: var(--card);
  min-height: 88rpx;
}

.select-text {
  font-size: 28rpx;
  color: var(--foreground);
}

.select-arrow {
  font-size: 24rpx;
  color: var(--muted-foreground);
}

/* 开关控件样式 */
.switch-group {
  border-top: 2rpx solid var(--border);
  padding-top: 20rpx;
}

.switch-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.macaron-switch {
  transform: scale(0.9);
}

.popup-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx 30rpx;
  border-top: 2rpx solid var(--border);
  flex-shrink: 0;
}

.popup-btn {
  flex: 1;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

/* 减少动画（可访问性） */
@media (prefers-reduced-motion: reduce) {
  .loading-spinner {
    animation: none;
  }
  
  .cartoon-card,
  .macaron-btn,
  .form-input-macaron {
    transition: none;
  }
}

/* ===== 实体电表关联区样式 ===== */
.meter-section {
  margin-top: 16rpx;
  margin-bottom: 20rpx;
}

.meter-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 4rpx;
  margin-bottom: 12rpx;
}

.meter-section-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  font-weight: 900;
  color: #8B7E74;
}

.meter-section-icon {
  width: 24rpx;
  height: 24rpx;
}

.meter-add-link {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  font-weight: var(--font-weight-bold);
  color: #3b82f6;
}

.meter-add-link:active {
  opacity: 0.7;
}

.meter-add-plus {
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
}

.meter-chips-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meter-chip {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.5);
  border: 4rpx solid #5E4E3E;
  border-radius: 24rpx;
  padding: 12rpx 24rpx;
  max-width: 280rpx;
}

.meter-chip-info {
  display: flex;
  flex-direction: column;
}

.meter-chip-area {
  font-size: 22rpx;
  font-weight: 900;
  color: #5E4E3E;
  line-height: 1;
}

.meter-chip-ip {
  font-size: 18rpx;
  font-weight: 700;
  color: #8B7E74;
  line-height: 1;
  margin-top: 4rpx;
  font-family: 'Menlo', 'Monaco', 'Courier New', monospace;
}

.meter-chip-actions {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.meter-chip-edit {
  padding: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.meter-action-icon {
  width: 20rpx;
  height: 20rpx;
}

.meter-chip-delete {
  padding: 4rpx 8rpx;
  color: #f87171;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
}

.meter-chip-delete:active {
  color: #dc2626;
}

.meter-chip-empty {
  font-size: 22rpx;
  color: rgba(139, 126, 116, 0.5);
  font-style: italic;
  padding: 8rpx 4rpx;
}

/* ===== 添加电表弹窗扩展样式 ===== */
.popup-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.popup-title-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  background: #dbeafe;
  border-radius: 24rpx;
  border: 4rpx solid #5E4E3E;
  box-shadow: 4rpx 4rpx 0rpx #5E4E3E;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.popup-title-icon {
  width: 44rpx;
  height: 44rpx;
}

.popup-title-text-group {
  display: flex;
  flex-direction: column;
}

.popup-subtitle-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #8B7E74;
  margin-top: 4rpx;
}

.form-label-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.form-label-icon {
  width: 24rpx;
  height: 24rpx;
}

.form-input-mono {
  font-family: 'Menlo', 'Monaco', 'Courier New', monospace;
}

/* 确认弹窗样式 */
.confirm-modal {
  background: white;
  border: 3rpx solid #5E4E3E;
  border-radius: 40rpx;
  padding: 60rpx 40rpx;
  width: 560rpx;
  max-width: 90%;
  text-align: center;
  box-shadow: 10rpx 10rpx 0rpx #5E4E3E;
}

.confirm-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  background: var(--color-pink-macaron);
  border: 3rpx solid #5E4E3E;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 40rpx;
  box-shadow: 4rpx 4rpx 0rpx #5E4E3E;
}

.confirm-icon {
  width: 64rpx;
  height: 64rpx;
}

.confirm-title {
  display: block;
  font-size: 44rpx;
  font-weight: 900;
  color: #5E4E3E;
  margin-bottom: 20rpx;
}

.confirm-message {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #8B7E74;
  line-height: 1.6;
  margin-bottom: 50rpx;
}

.confirm-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.confirm-btn {
  padding: 28rpx;
  border: 3rpx solid #5E4E3E;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 900;
  text-align: center;
  box-shadow: 4rpx 4rpx 0rpx #5E4E3E;
  transition: all 0.2s;
}

.confirm-btn:active {
  transform: translateY(2rpx);
  box-shadow: 2rpx 2rpx 0rpx #5E4E3E;
}

.confirm-btn-danger {
  background: var(--color-pink-macaron);
  color: #5E4E3E;
}

.confirm-btn-cancel {
  background: #F3F4F6;
  color: #5E4E3E;
}

/* 弹窗遮罩层 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

/* 编辑电表弹窗容器 */
.modal-container {
  background: #FDFCF8;
  border: 6rpx solid #5E4E3E;
  border-radius: 64rpx;
  width: 90%;
  max-width: 560rpx;
  padding: 48rpx;
  box-sizing: border-box;
  box-shadow: 16rpx 16rpx 0rpx #5E4E3E;
  position: relative;
}

/* 弹窗头部 - 简化版，不使用黄色背景 */
.modal-container .popup-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 64rpx;
  padding: 0;
  background: transparent;
  border: none;
  border-radius: 0;
}

.popup-title-group {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
}

.popup-title-icon-wrapper {
  width: 112rpx;
  height: 112rpx;
  background: var(--color-mint-macaron);
  border-radius: 32rpx;
  border: 6rpx solid #5E4E3E;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 6rpx 6rpx 0rpx #5E4E3E;
  flex-shrink: 0;
}

.popup-title-icon {
  width: 56rpx;
  height: 56rpx;
}

.popup-title-text-group {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.popup-title-text {
  font-size: 40rpx;
  font-weight: 900;
  color: #5E4E3E;
  line-height: 1.2;
}

.popup-subtitle-text {
  font-size: 20rpx;
  font-weight: 700;
  color: #8B7E74;
}

.modal-container .popup-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  border-radius: 50%;
  flex-shrink: 0;
}

.modal-container .popup-close:active {
  background: rgba(0, 0, 0, 0.05);
}

.modal-container .close-icon-img {
  width: 48rpx;
  height: 48rpx;
}

/* 表单组容器 */
.form-group-container {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  margin-bottom: 40rpx;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.form-label-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-left: 8rpx;
}

.form-label-icon {
  width: 24rpx;
  height: 24rpx;
}

.form-label {
  font-size: 24rpx;
  font-weight: 900;
  color: #5E4E3E;
}

/* 编辑电表弹窗输入框样式 */
.form-input {
  width: 100%;
  padding: 32rpx 40rpx;
  background: white;
  border: 6rpx solid #5E4E3E;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 900;
  color: #5E4E3E;
  box-sizing: border-box;
  line-height: 1.2;
  height: auto;
}

.form-input::placeholder {
  color: #8B7E74;
  font-weight: 700;
}

/* 弹窗按钮 */
.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  padding: 32rpx;
  border: 6rpx solid #5E4E3E;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 900;
  text-align: center;
  box-shadow: 8rpx 8rpx 0rpx #5E4E3E;
  transition: all 0.2s;
  line-height: 1;
}

.modal-btn:active {
  transform: translateY(4rpx);
  box-shadow: 4rpx 4rpx 0rpx #5E4E3E;
}

.modal-btn-cancel {
  background: #F3F4F6;
  color: #5E4E3E;
}

.modal-btn-confirm {
  background: var(--color-mint-macaron);
  color: #5E4E3E;
}

/* ===== IP 检测 & SN 结果样式 ===== */

/* IP 输入行：输入框 + 检测按钮 */
.ip-input-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.ip-input {
  flex: 1;
}

/* 检测按钮 */
.ip-check-btn {
  width: 96rpx;
  height: 96rpx;
  background: var(--color-lavender-macaron, #E8D5F5);
  border: 4rpx solid #5E4E3E;
  border-radius: 24rpx;
  box-shadow: 4rpx 4rpx 0rpx #5E4E3E;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.15s;
}

.ip-check-btn:active {
  transform: translateY(4rpx);
  box-shadow: 2rpx 2rpx 0rpx #5E4E3E;
}

.ip-check-btn-loading {
  opacity: 0.6;
}

.ip-check-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 旋转加载动画 */
.ip-check-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid #5E4E3E;
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* SN 检测结果框 */
.sn-result-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-radius: 24rpx;
  border: 4rpx solid #5E4E3E;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.sn-result-success {
  background: rgba(var(--color-mint-macaron-rgb, 180, 230, 200), 0.3);
}

.sn-result-error {
  background: var(--color-pink-macaron, #FFD6D6);
}

.sn-result-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.sn-result-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.sn-result-label {
  font-size: 22rpx;
  font-weight: 900;
  color: #5E4E3E;
}

.sn-result-value {
  font-size: 26rpx;
  font-weight: 900;
  color: #5E4E3E;
  font-family: monospace;
}

.sn-result-error-text {
  font-size: 24rpx;
  font-weight: 900;
  color: #dc2626;
  flex: 1;
}

.sn-online-badge {
  background: #22c55e;
  color: #fff;
  font-size: 20rpx;
  font-weight: 900;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}
