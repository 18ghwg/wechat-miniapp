/**
 * 骨架屏样式
 * 性能优化：首页加载时显示骨架屏，提升用户体验
 */

/* 骨架屏容器 */
.skeleton-screen {
  padding: 30rpx;
  background-color: #f5f5f5;
}

/* 骨架屏加载动画 */
@keyframes skeleton-loading {
  0% {
    background-position: -200rpx 0;
  }
  100% {
    background-position: calc(200rpx + 100%) 0;
  }
}

/* 骨架屏基础样式 */
.skeleton-item,
.skeleton-text,
.skeleton-icon,
.skeleton-announcement,
.skeleton-info,
.skeleton-section-title {
  background: linear-gradient(
    90deg,
    #f0f0f0 25%,
    #e0e0e0 50%,
    #f0f0f0 75%
  );
  background-size: 400rpx 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  border-radius: 8rpx;
}

/* 骨架屏标题 */
.skeleton-section-title {
  width: 200rpx;
  height: 40rpx;
  margin-bottom: 20rpx;
}

.skeleton-mt {
  margin-top: 40rpx;
}

/* 骨架屏网格 */
.skeleton-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

/* 骨架屏功能卡片 */
.skeleton-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  min-height: 200rpx;
}

/* 骨架屏图标 */
.skeleton-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

/* 骨架屏文本 */
.skeleton-text {
  width: 100%;
  height: 24rpx;
  margin-bottom: 12rpx;
}

.skeleton-text-short {
  width: 60%;
  height: 28rpx;
}

.skeleton-text-medium {
  width: 80%;
  height: 28rpx;
}

.skeleton-text-long {
  width: 100%;
  height: 20rpx;
}

/* 骨架屏公告区域 */
.skeleton-announcement {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 30rpx;
}

/* 骨架屏信息区域 */
.skeleton-info {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 优化：减少重绘 - 直接应用到具体元素 */
.skeleton-item,
.skeleton-text,
.skeleton-icon,
.skeleton-announcement,
.skeleton-info,
.skeleton-section-title {
  will-change: background-position;
}

/* 优化：使用transform代替top/left */
.skeleton-item {
  transform: translateZ(0);
  backface-visibility: hidden;
}

