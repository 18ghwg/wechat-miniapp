<!-- 小程序账号管理 - Macaron Theme -->
<wxs module="utils">
module.exports = {
  formatTime: function(timeStr) {
    if (!timeStr) return '未知';
    return timeStr;
  },
  getLevelText: function(level) {
    if (level === 'admin') return '管理员';
    if (level === 'viewer') return '访客';
    return '普通用户';
  }
}
</wxs>

<view class="miniprogram-users-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="header-icon-wrapper">
      <image class="header-icon" src="/assets/icons/users.png" mode="aspectFit" />
    </view>
    <text class="page-title">小程序账号管理</text>
    <text class="page-subtitle">管理小程序用户账号和权限</text>
  </view>

  <!-- 搜索栏 -->
  <view class="cartoon-card search-card">
    <view class="search-bar">
      <image class="search-icon" src="/assets/icons/search.png" mode="aspectFit" />
      <input 
        class="form-input-macaron search-input"
        placeholder="搜索用户昵称、姓名或OpenID" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearchConfirm"
      />
    </view>
    <view class="action-bar">
      <view 
        class="macaron-btn macaron-btn-mint action-btn" 
        bindtap="showCreateUserModal"
        wx:if="{{isAdmin}}"
      >
        <text class="btn-icon-text">+</text>
        <text>新增用户</text>
      </view>
      <view class="macaron-btn macaron-btn-blue action-btn" bindtap="onRefresh">
        <text class="btn-icon-text">↻</text>
        <text>刷新</text>
      </view>
    </view>
  </view>

  <!-- 用户统计信息 -->
  <view class="cartoon-card stats-card" wx:if="{{stats}}">
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-value">{{stats.total || 0}}</text>
        <text class="stat-label">总用户数</text>
      </view>
      <view class="stat-item stat-admin">
        <text class="stat-value">{{stats.admin_count || 0}}</text>
        <text class="stat-label">管理员</text>
      </view>
      <view class="stat-item stat-user">
        <text class="stat-value">{{stats.user_count || 0}}</text>
        <text class="stat-label">普通用户</text>
      </view>
      <view class="stat-item stat-viewer">
        <text class="stat-value">{{stats.viewer_count || 0}}</text>
        <text class="stat-label">访客</text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="cartoon-card loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="cartoon-card empty-state" wx:if="{{!loading && users.length === 0}}">
    <image class="empty-icon" src="/assets/icons/users.png" mode="aspectFit" />
    <text class="empty-title">暂无用户数据</text>
    <text class="empty-subtitle">{{searchKeyword ? '未找到匹配的用户' : '系统中还没有注册用户'}}</text>
  </view>

  <!-- 用户列表 -->
  <view class="user-list" wx:if="{{!loading && users.length > 0}}">
    <view 
      class="cartoon-card user-item" 
      wx:for="{{users}}" 
      wx:key="id" 
      bindtap="showUserDetail" 
      data-user="{{item}}"
    >
      <!-- 用户头像和状态 -->
      <view class="user-avatar-wrapper">
        <image 
          class="user-avatar" 
          src="{{userAvatars[item.id] || '/static/default-avatar.svg'}}" 
          mode="aspectFill" 
        />
        <view class="user-status-dot {{item.is_active ? 'active' : 'inactive'}}"></view>
      </view>
      
      <!-- 用户信息 -->
      <view class="user-info">
        <view class="user-header">
          <text class="user-nickname">{{item.nickname || '未设置昵称'}}</text>
          <view class="status-badge level-badge-{{item.user_level}}">
            {{utils.getLevelText(item.user_level)}}
          </view>
        </view>
        
        <view class="user-details">
          <text class="user-real-name" wx:if="{{item.real_name}}">
            <text class="detail-icon">👤</text> {{item.real_name}}
          </text>
          <text class="user-web-info" wx:if="{{item.web_username}}">
            <text class="detail-icon">🔗</text> 关联：{{item.web_username}}
          </text>
        </view>
        
        <view class="user-meta">
          <text class="meta-item">
            <text class="detail-icon">📅</text> 注册：{{utils.formatTime(item.register_time)}}
          </text>
          <text class="meta-item" wx:if="{{item.last_login}}">
            <text class="detail-icon">🕐</text> 最后登录：{{utils.formatTime(item.last_login)}}
          </text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="user-actions" catchtap="preventBubble" wx:if="{{isAdmin}}">
        <view 
          class="macaron-btn macaron-btn-yellow action-btn-small" 
          catchtap="showEditUserModal" 
          data-user="{{item}}"
        >
          <image class="btn-icon-small" src="/assets/icons/edit.png" mode="aspectFit" />
        </view>
        <view 
          class="macaron-btn macaron-btn-pink action-btn-small" 
          catchtap="deleteUser" 
          data-user="{{item}}"
          wx:if="{{item.openid !== currentUserOpenid}}"
        >
          <image class="btn-icon-small" src="/assets/icons/trash.png" mode="aspectFit" />
        </view>
      </view>
    </view>
  </view>

  <!-- 分页 -->
  <view class="pagination-container" wx:if="{{pagination && pagination.pages > 1}}">
    <view 
      class="macaron-btn macaron-btn-lavender pagination-btn {{!pagination.has_prev ? 'btn-disabled' : ''}}" 
      bindtap="changePage" 
      data-page="{{pagination.page - 1}}"
    >
      上一页
    </view>
    <view class="pagination-info">
      <text class="page-current">{{pagination.page}}</text>
      <text class="page-separator">/</text>
      <text class="page-total">{{pagination.pages}}</text>
    </view>
    <view 
      class="macaron-btn macaron-btn-lavender pagination-btn {{!pagination.has_next ? 'btn-disabled' : ''}}" 
      bindtap="changePage" 
      data-page="{{pagination.page + 1}}"
    >
      下一页
    </view>
  </view>
</view>

<!-- 创建用户弹窗 -->
<view class="popup-overlay" wx:if="{{showCreateModal}}" bindtap="hideCreateUserModal">
  <view class="cartoon-card popup-container" catchtap="preventBubble">
    <view class="popup-header">
      <text class="popup-title">新增用户</text>
      <view class="popup-close" bindtap="hideCreateUserModal">
        <image class="close-icon" src="/assets/icons/close.png" mode="aspectFit" />
      </view>
    </view>
    
    <view class="popup-content">
      <view class="form-group">
        <text class="form-label">昵称 <text class="required">*</text></text>
        <input 
          class="form-input-macaron {{createForm.errors.nickname ? 'input-error' : ''}}"
          placeholder="请输入用户昵称"
          value="{{createForm.nickname}}"
          bindinput="onCreateFormInput"
          data-field="nickname"
        />
        <text class="form-error" wx:if="{{createForm.errors.nickname}}">{{createForm.errors.nickname}}</text>
      </view>

      <view class="form-group">
        <text class="form-label">真实姓名</text>
        <input 
          class="form-input-macaron {{createForm.errors.real_name ? 'input-error' : ''}}"
          placeholder="请输入真实姓名（2-10个汉字）"
          value="{{createForm.real_name}}"
          bindinput="onCreateFormInput"
          data-field="real_name"
        />
        <text class="form-error" wx:if="{{createForm.errors.real_name}}">{{createForm.errors.real_name}}</text>
      </view>

      <view class="form-group">
        <text class="form-label">用户级别 <text class="required">*</text></text>
        <picker 
          class="form-picker-macaron {{createForm.errors.user_level ? 'input-error' : ''}}"
          range="{{userLevelOptions}}" 
          range-key="label"
          value="{{createForm.userLevelIndex}}"
          bindchange="onCreateUserLevelChange"
        >
          <view class="picker-display">
            <text class="picker-text">{{userLevelOptions[createForm.userLevelIndex].label}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
        <text class="form-error" wx:if="{{createForm.errors.user_level}}">{{createForm.errors.user_level}}</text>
      </view>
    </view>

    <view class="popup-footer">
      <view class="macaron-btn macaron-btn-lavender popup-btn" bindtap="hideCreateUserModal">取消</view>
      <view 
        class="macaron-btn macaron-btn-peach popup-btn {{createForm.submitting ? 'btn-disabled' : ''}}" 
        bindtap="submitCreateUser"
      >
        {{createForm.submitting ? '创建中...' : '创建'}}
      </view>
    </view>
  </view>
</view>

<!-- 编辑用户弹窗 -->
<view class="popup-overlay" wx:if="{{showEditModal}}" bindtap="hideEditUserModal">
  <view class="cartoon-card popup-container" catchtap="preventBubble">
    <view class="popup-header">
      <text class="popup-title">编辑用户</text>
      <view class="popup-close" bindtap="hideEditUserModal">
        <image class="close-icon" src="/assets/icons/close.png" mode="aspectFit" />
      </view>
    </view>
    
    <view class="popup-content">
      <view class="form-group">
        <text class="form-label">昵称</text>
        <input 
          class="form-input-macaron {{editForm.errors.nickname ? 'input-error' : ''}}"
          placeholder="请输入用户昵称"
          value="{{editForm.nickname}}"
          bindinput="onEditFormInput"
          data-field="nickname"
        />
        <text class="form-error" wx:if="{{editForm.errors.nickname}}">{{editForm.errors.nickname}}</text>
      </view>

      <view class="form-group">
        <text class="form-label">真实姓名</text>
        <input 
          class="form-input-macaron {{editForm.errors.real_name ? 'input-error' : ''}}"
          placeholder="请输入真实姓名（2-10个汉字）"
          value="{{editForm.real_name}}"
          bindinput="onEditFormInput"
          data-field="real_name"
        />
        <text class="form-error" wx:if="{{editForm.errors.real_name}}">{{editForm.errors.real_name}}</text>
      </view>

      <view class="form-group">
        <text class="form-label">用户级别</text>
        <picker 
          class="form-picker-macaron {{editForm.errors.user_level ? 'input-error' : ''}}"
          range="{{userLevelOptions}}" 
          range-key="label"
          value="{{editForm.userLevelIndex}}"
          bindchange="onEditUserLevelChange"
        >
          <view class="picker-display">
            <text class="picker-text">{{userLevelOptions[editForm.userLevelIndex].label}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
        <text class="form-error" wx:if="{{editForm.errors.user_level}}">{{editForm.errors.user_level}}</text>
      </view>

      <view class="form-group switch-group">
        <text class="form-label">账号状态</text>
        <view class="switch-wrapper">
          <switch 
            class="macaron-switch"
            checked="{{editForm.is_active}}" 
            bindchange="onEditActiveChange"
            color="#FF9F43"
          />
          <text class="switch-label">{{editForm.is_active ? '已激活' : '已禁用'}}</text>
        </view>
      </view>
    </view>

    <view class="popup-footer">
      <view class="macaron-btn macaron-btn-lavender popup-btn" bindtap="hideEditUserModal">取消</view>
      <view 
        class="macaron-btn macaron-btn-peach popup-btn {{editForm.submitting ? 'btn-disabled' : ''}}" 
        bindtap="submitEditUser"
      >
        {{editForm.submitting ? '保存中...' : '保存'}}
      </view>
    </view>
  </view>
</view>

<!-- 用户详情弹窗 -->
<view class="popup-overlay" wx:if="{{showDetailModal}}" bindtap="hideUserDetailModal">
  <view class="cartoon-card popup-container popup-large" catchtap="preventBubble">
    <view class="popup-header">
      <text class="popup-title">用户详情</text>
      <view class="popup-close" bindtap="hideUserDetailModal">
        <image class="close-icon" src="/assets/icons/close.png" mode="aspectFit" />
      </view>
    </view>
    
    <view class="popup-content" wx:if="{{selectedUser}}">
      <view class="detail-section">
        <text class="detail-section-title">基本信息</text>
        
        <view class="detail-row">
          <text class="detail-label">用户ID</text>
          <text class="detail-value">{{selectedUser.id}}</text>
        </view>
        
        <view class="detail-row">
          <text class="detail-label">OpenID</text>
          <text class="detail-value detail-value-small">{{selectedUser.openid}}</text>
        </view>
        
        <view class="detail-row">
          <text class="detail-label">昵称</text>
          <text class="detail-value">{{selectedUser.nickname || '未设置'}}</text>
        </view>
        
        <view class="detail-row">
          <text class="detail-label">真实姓名</text>
          <text class="detail-value">{{selectedUser.real_name || '未设置'}}</text>
        </view>
        
        <view class="detail-row">
          <text class="detail-label">用户级别</text>
          <view class="status-badge level-badge-{{selectedUser.user_level}}">
            {{utils.getLevelText(selectedUser.user_level)}}
          </view>
        </view>
        
        <view class="detail-row">
          <text class="detail-label">账号状态</text>
          <view class="status-badge {{selectedUser.is_active ? 'status-active' : 'status-inactive'}}">
            {{selectedUser.is_active ? '已激活' : '已禁用'}}
          </view>
        </view>
        
        <view class="detail-row" wx:if="{{selectedUser.web_username}}">
          <text class="detail-label">关联Web账号</text>
          <text class="detail-value">{{selectedUser.web_username}}</text>
        </view>
        
        <view class="detail-row">
          <text class="detail-label">注册时间</text>
          <text class="detail-value">{{utils.formatTime(selectedUser.register_time)}}</text>
        </view>
        
        <view class="detail-row" wx:if="{{selectedUser.last_login}}">
          <text class="detail-label">最后登录</text>
          <text class="detail-value">{{utils.formatTime(selectedUser.last_login)}}</text>
        </view>
      </view>

      <view class="detail-actions" wx:if="{{isAdmin}}">
        <view class="macaron-btn macaron-btn-blue detail-action-btn" bindtap="viewUserPermissions" data-user="{{selectedUser}}">
          <image class="btn-icon" src="/assets/icons/shield.png" mode="aspectFit" />
          <text>查看权限</text>
        </view>
        <view class="macaron-btn macaron-btn-yellow detail-action-btn" bindtap="viewUserLogs" data-user="{{selectedUser}}">
          <image class="btn-icon" src="/assets/icons/clipboard.png" mode="aspectFit" />
          <text>操作日志</text>
        </view>
      </view>
    </view>

    <view class="popup-footer">
      <view class="macaron-btn macaron-btn-lavender popup-btn-full" bindtap="hideUserDetailModal">关闭</view>
    </view>
  </view>
</view>

<!-- 隐藏的Canvas元素用于头像生成 (Canvas 2D) -->
<view class="hidden-canvas-container">
  <canvas 
    wx:for="{{users}}" 
    wx:key="id"
    type="2d"
    id="avatarCanvas_{{item.id}}"
    class="hidden-canvas"
    style="width: 120px; height: 120px; position: absolute; top: -9999px; left: -9999px;"
  ></canvas>
</view>
