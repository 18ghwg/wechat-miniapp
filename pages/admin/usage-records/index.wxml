<!-- 使用记录管理页面 - Macaron Theme -->
<wxs module="utils">
module.exports = {
  formatTime: function(timeStr) {
    if (!timeStr) return '未知';
    return timeStr;
  }
}
</wxs>

<view class="usage-records-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="header-icon-wrapper">
      <image class="header-icon" src="/assets/icons/bar-chart.png" mode="aspectFit" />
    </view>
    <text class="page-title">使用记录管理</text>
    <text class="page-subtitle">查看和管理功能使用统计</text>
  </view>

  <!-- 搜索和筛选区域 -->
  <view class="cartoon-card search-section">
    <view class="search-bar">
      <image class="search-icon" src="/assets/icons/search.png" mode="aspectFit" />
      <input 
        class="search-input"
        placeholder="搜索用户名或功能名"
        placeholder-style="color: var(--muted-foreground); font-size: 28rpx;"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
      />
    </view>
    
    <view class="filter-row">
      <picker mode="selector" range="{{featureOptions}}" range-key="label" value="{{featureFilterIndex}}" bindchange="onFeatureFilterChange">
        <view class="macaron-filter-btn">
          <image class="filter-icon" src="/assets/icons/filter.png" mode="aspectFit" />
          <text class="filter-text">{{featureOptions[featureFilterIndex].label}}</text>
          <text class="filter-arrow">▼</text>
        </view>
      </picker>
      
      <picker mode="date" value="{{dateFilter}}" bindchange="onDateFilterChange">
        <view class="macaron-filter-btn">
          <image class="filter-icon" src="/assets/icons/calendar.png" mode="aspectFit" />
          <text class="filter-text">{{dateFilter || '选择日期'}}</text>
          <text class="filter-arrow">▼</text>
        </view>
      </picker>
      
      <view class="macaron-filter-btn reset-btn" bindtap="resetFilters">
        <text class="filter-text">重置</text>
      </view>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-cards" wx:if="{{!loading && stats}}">
    <view class="cartoon-card stat-card stat-card-blue">
      <view class="stat-icon-wrapper stat-icon-blue">
        <image class="stat-icon" src="/assets/icons/bar-chart.png" mode="aspectFit" />
      </view>
      <view class="stat-content">
        <text class="stat-value">{{stats.total_records || 0}}</text>
        <text class="stat-label">总记录数</text>
      </view>
    </view>
    
    <view class="cartoon-card stat-card stat-card-mint">
      <view class="stat-icon-wrapper stat-icon-mint">
        <image class="stat-icon" src="/assets/icons/users.png" mode="aspectFit" />
      </view>
      <view class="stat-content">
        <text class="stat-value">{{stats.active_users || 0}}</text>
        <text class="stat-label">活跃用户</text>
      </view>
    </view>
    
    <view class="cartoon-card stat-card stat-card-peach">
      <view class="stat-icon-wrapper stat-icon-peach">
        <image class="stat-icon" src="/assets/icons/trending-up.png" mode="aspectFit" />
      </view>
      <view class="stat-content">
        <text class="stat-value stat-value-small">{{stats.most_used_feature_name || stats.most_used_feature || '-'}}</text>
        <text class="stat-label">最热功能</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮栏 -->
  <view class="action-bar">
    <view class="macaron-btn macaron-btn-mint action-button" bindtap="showAddDialog">
      <text class="btn-icon-text">+</text>
      <text>添加记录</text>
    </view>
    <view class="macaron-btn macaron-btn-lavender action-button" bindtap="exportRecords">
      <image class="btn-icon" src="/assets/icons/download.png" mode="aspectFit" />
      <text>导出数据</text>
    </view>
  </view>

  <!-- 使用记录列表 -->
  <view class="records-list" wx:if="{{!loading && records.length > 0}}">
    <view class="cartoon-card record-card" wx:for="{{records}}" wx:key="id">
      <view class="record-header">
        <view class="user-info">
          <view class="user-avatar-wrapper">
            <image class="user-avatar" src="/assets/icons/user.png" mode="aspectFit" />
          </view>
          <text class="user-name">{{item.user_name || item.nickname || '未知用户'}}</text>
        </view>
        <view class="record-time-wrapper">
          <image class="time-icon" src="/assets/icons/clock.png" mode="aspectFit" />
          <text class="record-time">{{utils.formatTime(item.created_at)}}</text>
        </view>
      </view>
      
      <view class="record-body">
        <view class="feature-info">
          <view class="feature-icon-wrapper">
            <text class="feature-emoji">{{item.feature_icon || '📱'}}</text>
          </view>
          <view class="feature-details">
            <text class="feature-name">{{item.feature_name}}</text>
            <text class="feature-key">{{item.feature_key}}</text>
          </view>
        </view>
      </view>
      
      <view class="record-footer">
        <view class="macaron-btn macaron-btn-yellow action-btn" bindtap="showEditDialog" data-record="{{item}}">
          <image class="btn-icon-small" src="/assets/icons/edit.png" mode="aspectFit" />
          <text>编辑</text>
        </view>
        <view class="macaron-btn macaron-btn-pink action-btn" bindtap="deleteRecord" data-id="{{item.id}}">
          <image class="btn-icon-small" src="/assets/icons/trash.png" mode="aspectFit" />
          <text>删除</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="cartoon-card empty-state" wx:if="{{!loading && records.length === 0}}">
    <image class="empty-icon" src="/assets/icons/bar-chart.png" mode="aspectFit" />
    <text class="empty-title">暂无使用记录</text>
    <text class="empty-subtitle">{{searchKeyword ? '没有找到匹配的记录' : '开始记录用户功能使用情况'}}</text>
  </view>

  <!-- 加载状态 -->
  <view class="cartoon-card loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 分页 -->
  <view class="pagination" wx:if="{{!loading && totalPages > 1}}">
    <view class="macaron-btn macaron-btn-lavender page-btn {{currentPage === 1 ? 'btn-disabled' : ''}}" bindtap="prevPage">
      上一页
    </view>
    <view class="page-info-wrapper">
      <text class="page-info">{{currentPage}} / {{totalPages}}</text>
    </view>
    <view class="macaron-btn macaron-btn-lavender page-btn {{currentPage === totalPages ? 'btn-disabled' : ''}}" bindtap="nextPage">
      下一页
    </view>
  </view>
</view>

<!-- 添加/编辑弹窗 -->
<view class="popup-overlay" wx:if="{{showDialog}}" bindtap="hideDialog">
  <view class="cartoon-card popup-container" catchtap="">
    <view class="popup-header">
      <text class="popup-title">{{editingRecord ? '编辑记录' : '添加记录'}}</text>
      <view class="popup-close" bindtap="hideDialog">
        <image class="close-icon" src="/assets/icons/close.png" mode="aspectFit" />
      </view>
    </view>
    
    <view class="popup-content">
      <view class="form-group">
        <text class="form-label">用户名 *</text>
        <input 
          class="form-input-macaron"
          placeholder="请输入用户名"
          placeholder-style="color: var(--muted-foreground); font-size: 28rpx;"
          value="{{formData.user_name}}"
          bindinput="onFormInput"
          data-field="user_name"
        />
      </view>
      
      <view class="form-group">
        <text class="form-label">功能标识 *</text>
        <input 
          class="form-input-macaron"
          placeholder="例如：electric"
          placeholder-style="color: var(--muted-foreground); font-size: 28rpx;"
          value="{{formData.feature_key}}"
          bindinput="onFormInput"
          data-field="feature_key"
        />
      </view>
      
      <view class="form-group">
        <text class="form-label">功能名称 *</text>
        <input 
          class="form-input-macaron"
          placeholder="例如：电费查询"
          placeholder-style="color: var(--muted-foreground); font-size: 28rpx;"
          value="{{formData.feature_name}}"
          bindinput="onFormInput"
          data-field="feature_name"
        />
      </view>
      
      <view class="form-group">
        <text class="form-label">功能图标</text>
        <input 
          class="form-input-macaron"
          placeholder="例如：⚡"
          placeholder-style="color: var(--muted-foreground); font-size: 28rpx;"
          value="{{formData.feature_icon}}"
          bindinput="onFormInput"
          data-field="feature_icon"
        />
        <text class="form-hint">输入一个 emoji 作为功能图标</text>
      </view>
    </view>
    
    <view class="popup-footer">
      <view class="macaron-btn macaron-btn-lavender popup-btn" bindtap="hideDialog">
        取消
      </view>
      <view class="macaron-btn macaron-btn-peach popup-btn" bindtap="submitForm">
        {{submitting ? '保存中...' : '确定'}}
      </view>
    </view>
  </view>
</view>
