/* 终端风格日志页面样式 - 马卡龙主题增强 */
@import '/style/macaron-theme.wxss';

/* 页面容器 */
.terminal-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #1e1e1e;
  font-family: 'Menlo', 'Monaco', 'Courier New', monospace;
}

/* 终端标题栏 - 马卡龙风格 */
.terminal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: linear-gradient(180deg, #3c3c3c 0%, #2d2d2d 100%);
  border-bottom: 4rpx solid var(--foreground);
}

.terminal-buttons {
  display: flex;
  gap: 12rpx;
}

.terminal-buttons view {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0, 0, 0, 0.2);
}

.btn-close {
  background: var(--color-pink-macaron);
}

.btn-minimize {
  background: var(--color-yellow-macaron);
}

.btn-maximize {
  background: var(--color-mint-macaron);
}

.terminal-title {
  flex: 1;
  text-align: center;
}

.terminal-title text {
  font-size: 26rpx;
  color: #ccc;
  font-weight: var(--font-weight-medium);
}

.terminal-controls {
  display: flex;
  gap: 16rpx;
}

.control-btn {
  width: 56rpx;
  height: 56rpx;
  min-width: 56rpx;
  min-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #444;
  border: 3rpx solid var(--foreground);
  transition: all 0.2s;
}

.control-btn:active {
  transform: scale(0.95);
}

.control-btn.active {
  background: var(--color-mint-macaron);
}

.control-btn text {
  font-size: 24rpx;
  color: #fff;
}

.control-btn.active text {
  color: var(--foreground);
}

/* 工具栏 - 马卡龙风格 */
.toolbar {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #252526;
  border-bottom: 3rpx solid var(--foreground);
  gap: 12rpx;
  flex-wrap: wrap;
}

.tool-item {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #3c3c3c;
  border-radius: 20rpx;
  gap: 8rpx;
  min-height: 44rpx;
}

.macaron-tool {
  border: 3rpx solid var(--foreground);
  background: var(--color-orange-light);
  transition: all 0.2s;
}

.macaron-tool:active {
  transform: scale(0.98);
  background: var(--color-yellow-macaron);
}

.tool-icon {
  font-size: 28rpx;
}

.tool-text {
  font-size: 24rpx;
  color: var(--foreground);
  font-weight: var(--font-weight-medium);
}

.search-box {
  flex: 1;
  min-width: 200rpx;
}

.search-input {
  flex: 1;
  font-size: 24rpx;
  color: var(--foreground);
  background: transparent;
}

.search-input::placeholder {
  color: var(--muted-foreground);
}

.clear-btn {
  min-width: 88rpx;
  justify-content: center;
}

/* 终端内容区 */
.terminal-body {
  flex: 1;
  padding: 16rpx;
  overflow-y: auto;
}

/* 日志行 */
.log-line {
  display: flex;
  align-items: flex-start;
  padding: 6rpx 0;
  line-height: 1.4;
  gap: 8rpx;
}

.log-line.system-line {
  color: var(--color-blue-macaron);
}

.prompt {
  color: var(--color-mint-macaron);
  font-weight: bold;
}

/* 时间戳 */
.log-timestamp {
  font-size: 22rpx;
  color: #666;
  flex-shrink: 0;
  width: 100rpx;
}

/* 日志级别标签 - 马卡龙风格 */
.log-level-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  font-weight: var(--font-weight-bold);
  border: 2rpx solid var(--foreground);
}

.log-level-tag.DEBUG {
  background: #444;
  color: #888;
}

.log-level-tag.INFO {
  background: var(--color-blue-macaron);
  color: var(--foreground);
}

.log-level-tag.WARNING {
  background: var(--color-yellow-macaron);
  color: var(--foreground);
}

.log-level-tag.ERROR {
  background: var(--color-pink-macaron);
  color: var(--foreground);
}

.log-level-tag.CRITICAL {
  background: var(--destructive);
  color: var(--destructive-foreground);
}

/* 日志文本 */
.log-text {
  font-size: 24rpx;
  color: #d4d4d4;
  word-break: break-all;
  flex: 1;
}

/* 不同级别的日志文本颜色 */
.log-line.DEBUG .log-text {
  color: #888;
}

.log-line.INFO .log-text {
  color: #d4d4d4;
}

.log-line.WARNING .log-text {
  color: var(--color-yellow-macaron);
}

.log-line.ERROR .log-text {
  color: var(--color-pink-macaron);
}

.log-line.CRITICAL .log-text {
  color: var(--destructive);
  font-weight: bold;
}

/* 闪烁动画 */
.blink {
  animation: blink 1s infinite;
}

@keyframes blink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0.3; }
}

/* 状态栏 - 马卡龙风格 */
.status-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: var(--color-peach-macaron);
  border-top: 4rpx solid var(--foreground);
  color: var(--foreground);
}

.status-left,
.status-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.status-badge-item {
  padding: 6rpx 16rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 20rpx;
  border: 2rpx solid var(--foreground);
}

.status-badge-item.active {
  background: var(--color-mint-macaron);
}

.status-item {
  font-size: 24rpx;
  font-weight: var(--font-weight-medium);
}

.page-btns {
  display: flex;
  gap: 12rpx;
}

.page-btn {
  width: 56rpx;
  height: 56rpx;
  min-width: 56rpx;
  min-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 12rpx;
  border: 3rpx solid var(--foreground);
  transition: all 0.2s;
}

.page-btn:active {
  transform: scale(0.95);
  background: var(--color-yellow-macaron);
}

.page-btn.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.page-btn text {
  font-size: 24rpx;
  color: var(--foreground);
  font-weight: var(--font-weight-bold);
}

/* 新日志高亮动画 */
.log-line.new-log {
  animation: highlight 2s ease-out;
}

@keyframes highlight {
  0% {
    background: rgba(185, 251, 192, 0.3);
  }
  100% {
    background: transparent;
  }
}

/* 减少动画（可访问性） */
@media (prefers-reduced-motion: reduce) {
  .blink,
  .log-line.new-log {
    animation: none;
  }
}
