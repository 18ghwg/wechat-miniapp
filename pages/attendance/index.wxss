  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.edit-popup {
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
