  max-width: 600rpx;
  background: #FFFFFF;
  border: 4rpx solid #5E4E3E;
  border-radius: 32rpx;
  box-shadow: 8rpx 8rpx 0 #5E4E3E;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.delete-progress-title {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: #5E4E3E;
  margin-bottom: 16rpx;
}

.delete-progress-desc {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #8B7E74;
  margin-bottom: 32rpx;
}

.delete-progress-bar-wrap {
  position: relative;
  margin-bottom: 24rpx;
  width: 100%;
}

.delete-progress-bar-bg {
  height: 48rpx;
  background: #f0f0f0;
  border-radius: 24rpx;
  border: 3rpx solid #5E4E3E;
  overflow: hidden;
}

.delete-progress-bar-fill {
  height: 100%;
  background: #FFB7C5;
  border-radius: 24rpx;
  transition: width 0.3s ease;
}

.delete-progress-percent {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 24rpx;
  font-weight: 900;
  color: #5E4E3E;
}

.delete-progress-tip {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: #8B7E74;
  opacity: 0.7;
}

/* ===== 删除结果弹窗样式 ===== */
.delete-result-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10000;
}

.delete-result-card {
  width: 580rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  border: 4rpx solid #5E4E3E;
  box-shadow: 8rpx 8rpx 0 #5E4E3E;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.delete-result-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-result-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx dashed #D1D5DB;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.delete-result-icon-inner {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-result-success .delete-result-icon-inner { background: #B5EAD7; }
.delete-result-fail .delete-result-icon-inner { background: #FFB7C5; }

.delete-result-icon-img { width: 48rpx; height: 48rpx; }

.delete-result-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #5E4E3E;
  margin-bottom: 24rpx;
}

.delete-steps-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.delete-step-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
}

.delete-step-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.delete-step-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #2E7D32;
  flex: 1;
}

.delete-step-fail {
  color: #C62828;
}

.delete-result-confirm-btn {
  width: 100%;
  background: #FFCBA4;
  color: #5E4E3E;
  border: 4rpx solid #5E4E3E;
  border-radius: 999rpx;
  box-shadow: 4rpx 4rpx 0 #5E4E3E;
  text-align: center;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 900;
}

.delete-result-confirm-btn:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 #5E4E3E;
}
