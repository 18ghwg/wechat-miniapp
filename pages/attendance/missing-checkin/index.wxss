/* 漏打卡补交页面 - 匹配 Figma / React MissingCheckInPage 设计 */
@import '/style/macaron-theme.wxss';

.page-container {
  min-height: 100vh;
  background: var(--background);
  display: flex;
  flex-direction: column;
  /* 隐藏溢出屏幕的部分 */
  overflow: hidden;
}

/* ===== Header ===== */
.page-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: #fff;
  box-sizing: border-box;
}

.back-btn {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid var(--foreground);
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 4rpx 4rpx 0rpx var(--foreground);
}

.back-btn:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: none;
}

.back-icon {
  width: 32rpx;
  height: 32rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 900;
  color: var(--foreground);
}

.header-divider {
  height: 6rpx;
  background: var(--foreground);
}

/* ===== Body ===== */
.page-body {
  flex: 1;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

/* ===== Step Section ===== */
.step-section {
  margin-bottom: 48rpx;
}

.step-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

.step-icon {
  width: 36rpx;
  height: 36rpx;
}

.step-text {
  font-size: 34rpx;
  font-weight: 900;
  color: var(--foreground);
}

/* ===== Card Wrapper ===== */
.card-wrap {
  box-sizing: border-box;
}

/* ===== Date Grid ===== */
/* 不用 grid，改用 flex + 固定宽度 */
.date-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  box-sizing: border-box;
}

.date-grid .card-wrap {
  /* 四列：(100% - 3*gap) / 4 */
  width: calc(25% - 12rpx);
}

.date-card {
  height: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  border: 4rpx solid rgba(94, 78, 62, 0.1);
  border-right-width: 10rpx;
  border-bottom-width: 10rpx;
  border-right-color: var(--foreground);
  border-bottom-color: var(--foreground);
  background: #fff;
  position: relative;
  box-sizing: border-box;
}

.date-card:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: none;
}

.date-card-selected {
  background: var(--color-peach-macaron);
  border-color: var(--foreground);
}

.date-card-date {
  font-size: 28rpx;
  font-weight: 900;
  color: #aaa;
}

.date-card-selected .date-card-date {
  color: var(--foreground);
}

.date-card-weekday {
  font-size: 22rpx;
  font-weight: 700;
  color: #ccc;
}

.date-card-selected .date-card-weekday {
  color: rgba(94, 78, 62, 0.6);
}

.date-check-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 32rpx;
  height: 32rpx;
  background: var(--color-mint-macaron);
  border: 4rpx solid var(--foreground);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 4rpx 4rpx 0rpx var(--foreground);
}

.date-check-icon {
  width: 18rpx;
  height: 18rpx;
}

/* ===== Type Grid ===== */
.type-grid {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  box-sizing: border-box;
}

.type-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  min-width: 0;
  overflow: hidden;
}

.type-card {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 28rpx 16rpx;
  border-radius: 20rpx;
  border: 3rpx solid rgba(94, 78, 62, 0.1);
  border-right-width: 6rpx;
  border-bottom-width: 6rpx;
  border-right-color: var(--foreground);
  border-bottom-color: var(--foreground);
  background: #fff;
  box-sizing: border-box;
}

.type-card:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: none;
}

.type-card-selected {
  border-color: var(--foreground);
}

.type-icon-box {
  width: 52rpx;
  height: 52rpx;
  border-radius: 10rpx;
  border: 2rpx solid var(--foreground);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.type-icon {
  width: 28rpx;
  height: 28rpx;
}

.type-label {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--foreground);
  word-break: break-all;
}

/* ===== Trip Fields ===== */
.trip-fields {
  margin-bottom: 48rpx;
  box-sizing: border-box;
}

.field-row {
  display: flex;
  gap: 20rpx;
  box-sizing: border-box;
}

.field-flex {
  flex: 1;
  min-width: 0;
}

.field-subsidy {
  width: 240rpx;
  flex-shrink: 0;
}

.field-group {
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.field-label {
  display: block;
  font-size: 26rpx;
  font-weight: 900;
  color: var(--foreground);
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}

.field-input-wrap {
  position: relative;
}

.field-input-icon {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 28rpx;
  height: 28rpx;
  z-index: 1;
}

.field-input {
  width: 100%;
  height: auto;
  padding: 32rpx 28rpx 32rpx 72rpx;
  border: 4rpx solid var(--foreground);
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 6rpx 6rpx 0rpx var(--foreground);
  font-size: 28rpx;
  font-weight: 700;
  color: var(--foreground);
  box-sizing: border-box;
  min-width: 0;
}

/* ===== Submit Bar ===== */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(44rpx + env(safe-area-inset-bottom));
  background: var(--background);
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  padding: 40rpx 0;
  border-radius: 48rpx;
  border: 8rpx solid var(--foreground);
  text-align: center;
  box-shadow: 0 20rpx 0rpx var(--foreground);
  box-sizing: border-box;
}

.submit-btn:active {
  transform: translateY(4rpx);
  box-shadow: 0 12rpx 0rpx var(--foreground);
}

.submit-btn-active {
  background: var(--color-peach-macaron);
}

.submit-btn-disabled {
  background: #e5e7eb;
  box-shadow: 0 20rpx 0rpx #ccc;
  border-color: var(--foreground);
  filter: grayscale(1);
}

.submit-btn-text {
  font-size: 38rpx;
  font-weight: 900;
  color: var(--foreground);
}

.submit-btn-disabled .submit-btn-text {
  color: var(--foreground);
}

/* ===== Progress Overlay ===== */
.progress-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(4px);
}

.progress-card {
  width: 100%;
  max-width: 600rpx;
  background: #fff;
  border: 6rpx solid var(--foreground);
  border-radius: var(--radius-cartoon);
  box-shadow: 12rpx 12rpx 0rpx var(--foreground);
  padding: 48rpx;
  text-align: center;
}

.progress-title {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: var(--foreground);
  margin-bottom: 16rpx;
}

.progress-desc {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #8B7E74;
  margin-bottom: 32rpx;
}

.progress-bar-wrap {
  position: relative;
  margin-bottom: 24rpx;
}

.progress-bar-bg {
  height: 48rpx;
  background: #f0f0f0;
  border-radius: 999rpx;
  border: 6rpx solid var(--foreground);
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: var(--color-peach-macaron);
  border-radius: 999rpx;
  transition: width 0.3s ease;
}

.progress-percent {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 22rpx;
  font-weight: 900;
  color: var(--foreground);
}

.progress-tip {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: #8B7E74;
  font-style: italic;
}

/* ===== Result Overlay ===== */
.result-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(4px);
}

.result-card {
  width: 100%;
  max-width: 560rpx;
  background: #fff;
  border: 6rpx solid var(--foreground);
  border-radius: var(--radius-cartoon);
  box-shadow: 12rpx 12rpx 0rpx var(--foreground);
  padding: 48rpx;
  text-align: center;
  position: relative;
}

.result-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-close-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.3;
}

.result-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  border: 6rpx dashed #e0e0e0;
  background: #f9f9f9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-icon-inner {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-icon-success .result-icon-inner {
  background: #FFEBCC;
}

.result-icon-fail .result-icon-inner {
  background: #FFB7C5;
}

.result-icon-img {
  width: 72rpx;
  height: 72rpx;
}

.result-title {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: var(--foreground);
}

.result-title-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.result-title-sparkle {
  width: 36rpx;
  height: 36rpx;
}

.result-msg {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #8B7E74;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.result-confirm-btn {
  width: 100%;
  padding: 24rpx 0;
  background: var(--color-mint-macaron);
  border: 4rpx solid var(--foreground);
  border-radius: 24rpx;
  box-shadow: 6rpx 6rpx 0rpx var(--foreground);
}

.result-confirm-btn:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0rpx var(--foreground);
}

.result-confirm-text {
  font-size: 30rpx;
  font-weight: 900;
  color: var(--foreground);
}

/* ===== Reduced Motion ===== */
@media (prefers-reduced-motion: reduce) {
  .progress-bar-fill,
  .submit-btn,
  .date-card,
  .type-card,
  .back-btn {
    transition: none;
  }
}
