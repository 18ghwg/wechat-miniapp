/* 网盘账号管理页面样式 */

.netdisk-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 页面标题 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 30rpx 50rpx 30rpx;
  background: linear-gradient(135deg, #007AFF 0%, #5856D6 100%);
  border-radius: 0 0 40rpx 40rpx;
  margin: -20rpx -20rpx 30rpx -20rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 122, 255, 0.15);
  position: relative;
  overflow: hidden;
}

.header-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  letter-spacing: 1rpx;
  line-height: 1.2;
}

.page-subtitle {
  font-size: 26rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.8);
  letter-spacing: 0.5rpx;
}

.header-decoration {
  position: relative;
  width: 120rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.decoration-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
}

.circle-1 {
  width: 60rpx;
  height: 60rpx;
  top: 10rpx;
  right: 20rpx;
  animation: float 3s ease-in-out infinite;
}

.circle-2 {
  width: 40rpx;
  height: 40rpx;
  top: 30rpx;
  right: 60rpx;
  animation: float 3s ease-in-out infinite 1s;
}

.circle-3 {
  width: 25rpx;
  height: 25rpx;
  top: 5rpx;
  right: 50rpx;
  animation: float 3s ease-in-out infinite 2s;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0) scale(1);
    opacity: 0.6;
  }
  50% {
    transform: translateY(-10rpx) scale(1.1);
    opacity: 1;
  }
}

/* 信息卡片 */
.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.user-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.user-badges {
  display: flex;
  gap: 12rpx;
}

.badge {
  font-size: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.badge.admin {
  background: #e8f4fd;
  color: #007AFF;
}

.badge.test {
  background: #fff3e0;
  color: #ff9500;
}

/* 表单区域 */
.form-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}


/* 选择器 */
.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #f8f9fa;
  border: 2rpx solid #e3e3e3;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-input:active {
  background: #f0f0f0;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #e3e3e3;
  border-top: 3rpx solid #007AFF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #999;
}

/* 表单内容 */
.form-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.form-input {
  padding: 24rpx;
  background: #f8f9fa;
  border: 2rpx solid #e3e3e3;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  transition: all 0.2s ease;
}

.form-input:focus {
  border-color: #007AFF;
  background: #fff;
}

.form-input.disabled {
  background: #f5f5f5;
  color: #999;
  border-color: #ddd;
}

/* 开关样式 */
.form-item.switch-item {
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 16rpx 0;
}

.form-item.switch-item .form-label {
  margin: 0;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

switch {
  transform: scale(0.9);
  flex-shrink: 0;
}

/* 禁用状态下的开关样式 */
switch[disabled] {
  opacity: 0.6;
}

/* 编辑按钮区域 */
.edit-section {
  margin-bottom: 30rpx;
}

.edit-action-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #fff 100%);
  border: 3rpx solid #007AFF;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #007AFF;
  box-shadow: 0 6rpx 20rpx rgba(0, 122, 255, 0.15);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.edit-action-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.6), transparent);
  transition: all 0.5s ease;
}

.edit-action-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 15rpx rgba(0, 122, 255, 0.2);
  background: linear-gradient(135deg, #e3f2fd 0%, #f0f8ff 100%);
}

.edit-action-btn:active::before {
  left: 100%;
}

.edit-action-btn icon {
  transition: all 0.2s ease;
}

.edit-action-btn:active icon {
  transform: scale(1.1);
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.action-btn.primary {
  background: #007AFF;
  color: #fff;
}

.action-btn.primary:active {
  background: #0056b3;
  transform: scale(0.98);
}

.action-btn.secondary {
  background: #f8f9fa;
  color: #666;
  border: 2rpx solid #e3e3e3;
}

.action-btn.secondary:active {
  background: #e9ecef;
  transform: scale(0.98);
}

.action-btn.danger {
  background: #ff4757;
  color: #fff;
}

.action-btn.danger:active {
  background: #ff3742;
  transform: scale(0.98);
}

/* 帮助信息 */
.help-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.help-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.help-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
}

.help-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.help-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}
